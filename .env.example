# Telegram Bot Configuration
# 1. Создайте бота через BotFather: https://t.me/botfather
# 2. Получите токен бота и ID чата где нужно получать сообщения
VITE_TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklmnoPQRstuvwxyzABCdefGHI
VITE_TELEGRAM_CHAT_ID=123456789

# WhatsApp Configuration - Вариант 1: Twilio (платный, надежный)
# Зарегистрируйтесь на https://www.twilio.com/
# Получите эти данные в консоли Twilio
VITE_TWILIO_ACCOUNT_SID=your_account_sid
VITE_TWILIO_AUTH_TOKEN=your_auth_token
VITE_TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
VITE_WHATSAPP_PHONE_TO=whatsapp:+1234567890

# WhatsApp Configuration - Вариант 2: Make.com (бесплатно/платно, более простой)
# Создайте сценарий на https://make.com/
# Скопируйте Webhook URL
VITE_MAKE_WEBHOOK_URL=https://hook.make.com/your-webhook-url-here
